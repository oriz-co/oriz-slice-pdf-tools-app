---
import { FAMILY, FAMILY_SITES } from '@chirag127/oriz-ui'
import { SITE_CONFIG } from '~/lib/siteConfig'
const year = new Date().getFullYear()
const familyOthers = FAMILY_SITES.filter((s) => s.slug !== 'pdf-tools')
---

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-col">
      <p class="footer-brand">📄 {SITE_CONFIG.name}</p>
      <p class="footer-tag">{SITE_CONFIG.tagline}</p>
      <p class="footer-tag">
        Part of the <a href={FAMILY.rootOrigin}>{FAMILY.brand}</a> family by{' '}
        <a href={`${FAMILY.rootOrigin}/about/`}>{FAMILY.operator.name}</a>.
      </p>
    </div>

    <div class="footer-col">
      <h2 class="footer-h">Site</h2>
      <ul class="footer-links">
        <li><a href="/">All tools</a></li>
        <li><a href="/blog/">Blog</a></li>
        <li><a href="/about/">About</a></li>
        <li><a href="/contact/">Contact</a></li>
        <li><a href="/account/">Account</a></li>
      </ul>
    </div>

    <div class="footer-col">
      <h2 class="footer-h">Family</h2>
      <ul class="footer-links">
        {familyOthers.map((s) => <li><a href={s.url}>{s.emoji} {s.name}</a></li>)}
      </ul>
    </div>

    <div class="footer-col">
      <h2 class="footer-h">Legal</h2>
      <ul class="footer-links">
        <li><a href="/legal/privacy/">Privacy</a></li>
        <li><a href="/legal/terms/">Terms</a></li>
        <li><a href="/legal/disclaimer/">Disclaimer</a></li>
        <li><a href="/legal/cookies/">Cookies</a></li>
        <li><a href="/legal/grievance/">Grievance officer</a></li>
      </ul>
    </div>
  </div>

  <div class="footer-bottom">
    <p>&copy; {year} {FAMILY.operator.name}. All sites built with <a href={`https://github.com/${FAMILY.operator.githubHandle}/oriz`}>oriz</a>.</p>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 6rem;
    padding-block: 3rem 1.5rem;
    border-top: 1px solid var(--color-border);
    background: var(--color-bg-soft);
  }
  .footer-inner {
    max-width: var(--container-page, 1200px);
    margin-inline: auto;
    padding-inline: clamp(1rem, 4vw, 2rem);
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  @media (min-width: 640px) { .footer-inner { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .footer-inner { grid-template-columns: 2fr 1fr 1fr 1fr; } }
  .footer-brand {
    font-family: var(--font-serif, Georgia, serif);
    font-size: 1.5rem;
    font-weight: 600;
    margin: 0 0 0.5rem;
  }
  .footer-tag { color: var(--color-fg-muted); margin: 0 0 0.5rem; max-width: 36ch; }
  .footer-tag a { color: var(--color-fg); }
  .footer-h {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-fg-muted);
    margin: 0 0 0.75rem;
  }
  .footer-links { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.5rem; }
  .footer-links a { color: var(--color-fg-muted); text-decoration: none; font-size: 0.9375rem; }
  .footer-links a:hover { color: var(--color-fg); }
  .footer-bottom {
    max-width: var(--container-page, 1200px);
    margin: 2.5rem auto 0;
    padding: 1.5rem clamp(1rem, 4vw, 2rem) 0;
    border-top: 1px solid var(--color-border);
    color: var(--color-fg-soft);
    font-size: 0.8125rem;
  }
  .footer-bottom p { margin: 0; }
  .footer-bottom a { color: var(--color-fg-muted); }
</style>
