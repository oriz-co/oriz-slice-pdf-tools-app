---
/**
 * Site sidebar — left rail on desktop, slide-over on mobile. Renders sections
 * specific to PDF Tools (Organize, Convert, Edit, Security, AI) plus a Family
 * quick-jump at the bottom. Wraps the @chirag127/oriz-ui Sidebar React island.
 */
import { Sidebar, FAMILY_SITES } from '@chirag127/oriz-ui'
import { tools, categories } from '~/data/tools'

const toolSections = categories.map((cat) => ({
  title: cat.label,
  links: tools
    .filter((t) => t.category === cat.id)
    .map((t) => ({ label: t.name, href: `/tools/${t.slug}/` })),
}))

const familySection = {
  title: 'Family',
  links: FAMILY_SITES.filter((s) => s.slug !== 'pdf-tools').map((s) => ({
    label: `${s.emoji} ${s.name}`,
    href: s.url,
  })),
}

const sections = [
  { title: 'Browse', links: [
    { label: 'All tools', href: '/' },
    { label: 'Blog', href: '/blog/' },
    { label: 'About', href: '/about/' },
    { label: 'Contact', href: '/contact/' },
  ]},
  ...toolSections,
  familySection,
]
---

<Sidebar
  client:idle
  siteName="PDF Tools"
  siteSlug="pdf"
  sections={sections}
/>
