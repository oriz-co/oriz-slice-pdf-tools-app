---
import HeaderControls from '~/components/HeaderControls.tsx'
import { FAMILY, FAMILY_SITES } from '@chirag127/oriz-ui'
import { SITE_CONFIG } from '~/lib/siteConfig'
---

<header class="site-header">
  <div class="header-inner">
    <a href={FAMILY.rootOrigin} class="brand" aria-label={`${FAMILY.brand} home`}>
      <span class="brand-mark">{FAMILY.brand}</span>
      <span class="brand-dot">.</span>
    </a>
    <span class="site-badge" aria-hidden="true">📄 {SITE_CONFIG.name}</span>

    <nav aria-label="Primary" class="primary-nav">
      <a href="/">Tools</a>
      <a href="/blog/">Blog</a>
      <a href="/about/">About</a>
      <a href="/contact/">Contact</a>
    </nav>

    <HeaderControls client:idle sites={FAMILY_SITES} />
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in oklab, var(--color-bg) 85%, transparent);
    backdrop-filter: saturate(180%) blur(20px);
    -webkit-backdrop-filter: saturate(180%) blur(20px);
    border-bottom: 1px solid var(--color-border);
  }
  .header-inner {
    max-width: var(--container-page, 1200px);
    margin-inline: auto;
    padding-inline: clamp(1rem, 4vw, 2rem);
    height: 64px;
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .brand {
    font-family: var(--font-serif, Georgia, serif);
    font-size: 1.25rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    text-decoration: none;
    color: var(--color-fg);
    line-height: 1;
  }
  .brand-dot {
    color: var(--color-accent);
  }
  .site-badge {
    display: none;
    padding: 0.25rem 0.625rem;
    border-radius: 999px;
    background: var(--color-bg-soft);
    border: 1px solid var(--color-border);
    color: var(--color-fg-muted);
    font-size: 0.75rem;
    font-weight: 500;
  }
  .primary-nav {
    display: none;
    gap: 1.25rem;
    flex: 1;
    font-size: 0.9375rem;
  }
  .primary-nav a {
    color: var(--color-fg-muted);
    text-decoration: none;
  }
  .primary-nav a:hover {
    color: var(--color-fg);
  }
  @media (min-width: 768px) {
    .site-badge {
      display: inline-flex;
    }
    .primary-nav {
      display: flex;
      margin-left: 0.5rem;
    }
  }
</style>
