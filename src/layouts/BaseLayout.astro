---
import '~/styles/global.css'
import '@chirag127/astro-shell/tokens.css'
import FamilyChrome from '@chirag127/astro-shell/components/FamilyChrome.astro'
import FamilySidebar from '@chirag127/astro-shell/components/FamilySidebar.astro'
import Header from '~/components/Header.astro'
import Sidebar from '@chirag127/astro-chrome/Sidebar.astro'
import Footer from '@chirag127/astro-chrome/Footer.astro'
import BottomBar from '@chirag127/astro-chrome/BottomBar.astro'
import AppSidebarContent from '~/components/AppSidebarContent.astro'
import { bottomBarActions } from '~/data/bottombar-actions'
import { SITE_CONFIG } from '~/lib/siteConfig'

interface Props {
  title?: string
  description?: string
  canonical?: string
  noindex?: boolean
  jsonLd?: Record<string, unknown> | Record<string, unknown>[]
  noRunningFoot?: boolean
  pageNum?: string
  hideSidebar?: boolean
}

const {
  title = `${SITE_CONFIG.name} — ${SITE_CONFIG.tagline}`,
  description = SITE_CONFIG.description,
  canonical = `${SITE_CONFIG.origin}${Astro.url.pathname}`,
  noindex = false,
  jsonLd,
  noRunningFoot = false,
  pageNum = '1',
} = Astro.props

const beaconToken = import.meta.env.PUBLIC_CF_BEACON_TOKEN
const ga4Id = import.meta.env.PUBLIC_GA4_ID
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex" />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE_CONFIG.name} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@chirag127" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Source+Serif+4:opsz,ital,wght@8..60,0,400;8..60,0,500;8..60,0,600;8..60,1,400;8..60,1,500&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    {
      jsonLd && (
        <script
          is:inline
          type="application/ld+json"
          set:html={JSON.stringify(Array.isArray(jsonLd) ? jsonLd : [jsonLd])}
        />
      )
    }

    {
      beaconToken && (
        <script
          is:inline
          defer
          src="https://static.cloudflareinsights.com/beacon.min.js"
          data-cf-beacon={`{"token": "${beaconToken}"}`}
        />
      )
    }

    {
      ga4Id && (
        <>
          <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${ga4Id}`} />
          <script
            is:inline
            set:html={`window.dataLayer = window.dataLayer || []; function gtag(){dataLayer.push(arguments);} gtag('js', new Date()); gtag('config', '${ga4Id}');`}
          />
        </>
      )
    }
  </head>
  <body>
    <FamilyChrome slug="oriz-slice-pdf-tools-app" title="PDF" accent="#c1440e" />
    <a href="#main" class="skip-link">Skip to content</a>
    <Header />
    <Sidebar>
      <AppSidebarContent />
    </Sidebar>
    <main id="main">
      <div class="oriz-shell">
        <FamilySidebar slug="oriz-slice-pdf-tools-app" title="PDF Tools">
          <a slot="tools" href="/tools/merge-pdf/">Merge PDF</a>
          <a slot="tools" href="/tools/split-pdf/">Split PDF</a>
          <a slot="tools" href="/tools/remove-pages/">Remove Pages</a>
          <a slot="tools" href="/tools/extract-pages/">Extract Pages</a>
          <a slot="tools" href="/tools/organize-pdf/">Organize PDF</a>
          <a slot="tools" href="/tools/scan-to-pdf/">Scan to PDF</a>
          <a slot="tools" href="/tools/compress-pdf/">Compress PDF</a>
          <a slot="tools" href="/tools/optimize-pdf/">Optimize PDF</a>
          <a slot="tools" href="/tools/repair-pdf/">Repair PDF</a>
          <a slot="tools" href="/tools/ocr-pdf/">OCR PDF</a>
          <a slot="tools" href="/tools/jpg-to-pdf/">JPG to PDF</a>
          <a slot="tools" href="/tools/word-to-pdf/">Word to PDF</a>
          <a slot="tools" href="/tools/powerpoint-to-pdf/">PowerPoint to PDF</a>
          <a slot="tools" href="/tools/excel-to-pdf/">Excel to PDF</a>
          <a slot="tools" href="/tools/html-to-pdf/">HTML to PDF</a>
          <a slot="tools" href="/tools/pdf-to-jpg/">PDF to JPG</a>
          <a slot="tools" href="/tools/pdf-to-word/">PDF to Word</a>
          <a slot="tools" href="/tools/pdf-to-powerpoint/">PDF to PowerPoint</a>
          <a slot="tools" href="/tools/pdf-to-excel/">PDF to Excel</a>
          <a slot="tools" href="/tools/pdf-to-pdfa/">PDF to PDF/A</a>
          <a slot="tools" href="/tools/rotate-pdf/">Rotate PDF</a>
          <a slot="tools" href="/tools/add-page-numbers/">Add Page Numbers</a>
          <a slot="tools" href="/tools/add-watermark/">Add Watermark</a>
          <a slot="tools" href="/tools/crop-pdf/">Crop PDF</a>
          <a slot="tools" href="/tools/pdf-metadata/">Edit PDF Metadata</a>
          <a slot="tools" href="/tools/pdf-word-count/">PDF Word Count</a>
          <a slot="tools" href="/tools/unlock-pdf/">Unlock PDF</a>
          <a slot="tools" href="/tools/protect-pdf/">Protect PDF</a>
          <a slot="tools" href="/tools/sign-pdf/">Sign PDF</a>
          <a slot="tools" href="/tools/redact-pdf/">Redact PDF</a>
          <a slot="tools" href="/tools/compare-pdf/">Compare PDF</a>
          <a slot="tools" href="/tools/ai-summarizer/">AI Summarizer</a>
        </FamilySidebar>
        <main class="oriz-main">
          <slot />
        </main>
      </div>
      {!noRunningFoot && (
        <div class="running-foot" aria-hidden="false">
          <span class="page-num">— {pageNum} —</span>
          <span class="domain">pdf-tools.oriz.in</span>
        </div>
      )}
    </main>
    <Footer />
    <BottomBar actions={bottomBarActions} />
  </body>
</html>
