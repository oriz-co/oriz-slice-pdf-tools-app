---
import BaseLayout from '~/layouts/BaseLayout.astro'
import { FinishSignIn } from '@chirag127/oriz-ui'
---

<BaseLayout
  title="Finishing sign-in — PDF Tools"
  description="Completing email-link sign-in."
  noindex={true}
  hideSidebar={true}
>
  <section class="finish">
    <FinishSignIn client:load />
  </section>
</BaseLayout>

<style>
  .finish {
    max-width: var(--container-prose, 720px);
    margin-inline: auto;
    padding-block: 5rem 4rem;
    text-align: center;
  }
</style>
