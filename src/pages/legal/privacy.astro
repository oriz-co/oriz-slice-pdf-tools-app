---
import BaseLayout from '~/layouts/BaseLayout.astro'

const updated = '2026-06-19'
---

<BaseLayout title="Privacy policy — PDF Tools" description="What pdf.oriz.in collects, what it doesn't, and your rights." hideSidebar={true}>
  <header class="page-head">
    <p class="eyebrow"><a href="/">PDF Tools</a> / <a href="/legal/">Legal</a> / Privacy</p>
    <h1>Privacy policy</h1>
    <p class="meta">Last updated: {updated}</p>
  </header>

  <article class="prose">
    <h2>Who runs this</h2>
    <p>
      pdf.oriz.in and every <code>*.oriz.in</code> subdomain are operated by Chirag Singhal,
      based in Bhubaneswar, Odisha, India. Contact:
      <a href="mailto:whyiswhen@gmail.com">whyiswhen@gmail.com</a>.
    </p>

    <h2>What we collect</h2>
    <ul>
      <li>
        <strong>Your PDFs: nothing.</strong> Every tool on pdf.oriz.in runs entirely in
        your browser using <code>pdf-lib</code>, <code>pdfjs-dist</code>, and <code>tesseract.js</code>.
        Files you load are processed locally and never leave your device.
      </li>
      <li>
        <strong>Cloudflare Web Analytics</strong> — aggregate page views and country.
        Cookieless. No personal identifiers.
      </li>
      <li>
        <strong>Authentication</strong> — if you sign in, Firebase Authentication stores
        your email, display name, and profile photo (if you sign in with Google/GitHub).
        We never see your password.
      </li>
      <li>
        <strong>Site-specific preferences</strong> — recently-used tools, theme, and
        accent are stored in your browser's <code>localStorage</code> on this device only.
      </li>
      <li>
        <strong>Contact form</strong> — submissions go through Web3Forms which
        forwards them to my email. Web3Forms keeps copies; see their privacy policy.
      </li>
      <li>
        <strong>Display ads</strong> — once approved, Google AdSense may set
        cookies to personalize ads. You can opt out via the consent banner or
        at <a href="https://adssettings.google.com">adssettings.google.com</a>.
      </li>
    </ul>

    <h2>What we don't do</h2>
    <ul>
      <li>No uploading, scanning, or reading of the PDFs you process.</li>
      <li>No tracking across sessions for analytics (Cloudflare is anonymous).</li>
      <li>No selling of personal data to third parties.</li>
      <li>No newsletters unless you explicitly subscribe.</li>
    </ul>

    <h2>Your rights</h2>
    <p>
      You can delete your account from the <a href="/account/">account page</a>;
      this removes your Firebase Auth record. Under India's DPDP Act 2023, you have
      the right to access, correct, and delete your personal data. Contact the
      <a href="/legal/grievance/">grievance officer</a>.
    </p>

    <h2>Children</h2>
    <p>
      pdf.oriz.in is not directed at children under 13. If you believe a child has
      provided data to us, contact the grievance officer for removal.
    </p>

    <h2>Changes</h2>
    <p>
      We will update this page when the practice changes, with the new date
      at the top. Material changes get a banner on the site.
    </p>
  </article>
</BaseLayout>

<style>
  .page-head { max-width: var(--container-prose, 720px); margin-inline: auto; padding-block: 3rem 1.5rem; border-bottom: 1px solid var(--color-border); }
  .eyebrow { color: var(--color-fg-muted); font-size: 0.8125rem; margin: 0 0 0.5rem; }
  .eyebrow a { color: var(--color-fg-muted); text-decoration: none; }
  h1 { font-family: var(--font-serif, Georgia, serif); font-size: clamp(2rem, 4vw, 2.75rem); font-weight: 600; letter-spacing: -0.02em; margin: 0; }
  .meta { color: var(--color-fg-soft); font-size: 0.875rem; margin: 0.5rem 0 0; }
  .prose { max-width: var(--container-prose, 720px); margin-inline: auto; padding-block: 2.5rem 4rem; color: var(--color-prose); line-height: 1.7; font-size: 1.0625rem; }
  .prose h2 { font-family: var(--font-serif, Georgia, serif); font-size: 1.375rem; font-weight: 600; color: var(--color-fg); margin: 2rem 0 1rem; }
  .prose ul { padding-left: 1.5rem; margin: 0 0 1.25rem; }
  .prose li { margin-bottom: 0.5rem; }
  .prose p { margin: 0 0 1.25rem; }
  .prose a { color: var(--color-accent); }
  .prose code { background: var(--color-bg-muted); padding: 0.125em 0.375em; border-radius: 0.25rem; font-size: 0.875em; }
</style>
