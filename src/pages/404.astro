---
import BaseLayout from '~/layouts/BaseLayout.astro'
---

<BaseLayout title="404 — Page not found" description="The page you're looking for doesn't exist on PDF Tools." noindex={true} hideSidebar={true}>
  <section class="notfound">
    <p class="emoji" aria-hidden="true">📄</p>
    <h1>404 — Page not found</h1>
    <p>The page you're looking for doesn't exist. Try one of these:</p>
    <ul>
      <li><a href="/">All PDF tools</a></li>
      <li><a href="/blog/">Blog</a></li>
      <li><a href="/about/">About</a></li>
      <li><a href="/contact/">Contact</a></li>
    </ul>
  </section>
</BaseLayout>

<style>
  .notfound { max-width: var(--container-prose, 720px); margin-inline: auto; padding-block: 5rem 4rem; text-align: center; }
  .emoji { font-size: 3rem; margin: 0 0 1rem; }
  h1 { font-family: var(--font-serif, Georgia, serif); font-size: clamp(1.75rem, 4vw, 2.5rem); font-weight: 600; letter-spacing: -0.02em; margin: 0 0 1rem; }
  p { color: var(--color-fg-muted); margin: 0 0 1.5rem; }
  ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.5rem; align-items: center; }
  ul a { color: var(--color-accent); }
</style>
