---
import BaseLayout from '~/layouts/BaseLayout.astro'
import { AccountPanel } from '@chirag127/oriz-ui'
---

<BaseLayout
  title="Account — PDF Tools"
  description="Sign in to PDF Tools. One account works across every oriz site."
  noindex={true}
  hideSidebar={true}
>
  <header class="page-head">
    <p class="eyebrow"><a href="/">PDF Tools</a> / Account</p>
    <h1>Account</h1>
    <p class="lede">
      One sign-in works across every oriz site. Bookmarks, reading history, and
      preferences follow you.
    </p>
  </header>

  <section class="panel">
    <AccountPanel client:load />
  </section>
</BaseLayout>

<style>
  .page-head {
    max-width: var(--container-prose, 720px);
    margin-inline: auto;
    padding-block: 3rem 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }
  .eyebrow { color: var(--color-fg-muted); font-size: 0.8125rem; margin: 0 0 0.5rem; }
  .eyebrow a { color: var(--color-fg-muted); text-decoration: none; }
  h1 { font-family: var(--font-serif, Georgia, serif); font-size: clamp(2rem, 4vw, 2.75rem); font-weight: 600; letter-spacing: -0.02em; margin: 0; }
  .lede { color: var(--color-fg-muted); margin: 0.75rem 0 0; font-size: 1.0625rem; max-width: 56ch; }
  .panel { max-width: var(--container-prose, 720px); margin-inline: auto; padding-block: 2rem 4rem; }
</style>
